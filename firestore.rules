rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /clients/{doc} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth.uid == 'WRiA3GSPgCSkON3Vs38B59iZyru1';
    }
  }
}